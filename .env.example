# ── Supabase ─────────────────────────────────────────────────────────────
# Project Settings → API in your Supabase dashboard
# Obligatorio para reseñas, reportes, descargas y galería real.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Service role key — server-only, NEVER expose with NEXT_PUBLIC_. Used by
# admin routes to bypass RLS (upload images, moderate reviews, etc).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── NextAuth (admin panel login) ────────────────────────────────────────
# Generado automáticamente por: npm run setup
# Manual: openssl rand -base64 32   (o en PowerShell: ver README)
NEXTAUTH_SECRET=replace-with-a-random-secret
NEXTAUTH_URL=http://localhost:3000

# GitHub OAuth App → Settings → Developer settings → OAuth Apps
# Homepage URL: http://localhost:3000
# Callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=your-github-oauth-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-client-secret

# Comma-separated list of GitHub account emails allowed into /admin
ADMIN_EMAILS=you@example.com

# ── App content (opcional) ───────────────────────────────────────────────
NEXT_PUBLIC_GITHUB_REPO_URL=https://github.com/migol-dev/finance-mate
NEXT_PUBLIC_APP_VERSION=1.17.8
